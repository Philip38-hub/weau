# JWT Secret for signing tokens (generate a strong secret for production)
JWT_SECRET=your_jwt_secret_key_here

# Database URL (Railway will provide this automatically)
# For local development with PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/weau

# Google OAuth Client ID (for production)
# GOOGLE_WEB_CLIENT_ID=your_google_client_id_here

# Environment
NODE_ENV=production